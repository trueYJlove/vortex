# ============================================================================
# Halo Environment Variables Example
# ============================================================================
#
# Copy this file to .env.local and fill in your values
# .env.local is gitignored and will not be committed
#
# ============================================================================

# GitHub Token (for publishing to GitHub Releases)
# Get it: https://github.com/settings/tokens
# Required permissions: repo (Full control of private repositories)
GH_TOKEN=your_github_token_here

# E2E Test API Configuration (optional, for running E2E tests)
# Also used by i18n translation script (npm run i18n:translate)
#
# Supports both Anthropic and OpenAI-compatible APIs:
#
# --- Anthropic (auto-detected) ---
# HALO_TEST_API_KEY=sk-ant-xxx
# HALO_TEST_API_URL=https://api.anthropic.com
# HALO_TEST_MODEL=claude-haiku-4-5-20251001
#
# --- OpenAI ---
# HALO_TEST_API_KEY=sk-xxx
# HALO_TEST_API_URL=https://api.openai.com
# HALO_TEST_MODEL=gpt-4o-mini
#
# --- DeepSeek ---
# HALO_TEST_API_KEY=sk-xxx
# HALO_TEST_API_URL=https://api.deepseek.com
# HALO_TEST_MODEL=deepseek-chat
#
# --- Moonshot (Kimi) ---
# HALO_TEST_API_KEY=sk-xxx
# HALO_TEST_API_URL=https://api.moonshot.cn
# HALO_TEST_MODEL=moonshot-v1-8k
#
# --- Other OpenAI-compatible APIs ---
# HALO_TEST_API_KEY=your_api_key
# HALO_TEST_API_URL=https://your-api-endpoint.com
# HALO_TEST_MODEL=your-model-name
# HALO_TEST_PROVIDER=openai  # Provider ID (must match BUILTIN_PROVIDERS id)
#
HALO_TEST_API_KEY=your_test_api_key
HALO_TEST_API_URL=https://api.anthropic.com
HALO_TEST_MODEL=claude-sonnet-5
HALO_TEST_PROVIDER=anthropic

# ============================================================================
# Analytics Configuration (optional)
# ============================================================================
# If not configured, analytics will be disabled in your build.
# This is the expected behavior for open-source self-builds.
#
# To enable analytics in your own build:
# 1. Create a Google Analytics 4 property and get Measurement ID + API Secret
# 2. Create a Baidu Analytics account and get Site ID
# 3. Fill in the values below

# Google Analytics 4
# Get Measurement ID: GA4 Admin -> Data Streams -> Select stream -> Measurement ID
# Get API Secret: GA4 Admin -> Data Streams -> Select stream -> Measurement Protocol API secrets
HALO_GA_MEASUREMENT_ID=
HALO_GA_API_SECRET=

# Baidu Analytics (for China region)
# Get Site ID: https://tongji.baidu.com/
HALO_BAIDU_SITE_ID=

# ============================================================================
# Self-hosted Telemetry Backend (optional)
# ============================================================================
# Privacy-safe telemetry for session, page view, message count, and digital
# human run lifecycle events. When either value is empty the telemetry
# provider is disabled (default for open-source builds).
#
# Endpoint contract:
#   POST {endpoint}/v1/events
#   Authorization: Bearer {apiKey}
#   body: { sent_at, context, events[] }
#
# Example for an enterprise internal deployment:
#   HALO_TELEMETRY_ENDPOINT=https://telemetry.example.com
#   HALO_TELEMETRY_API_KEY=internal-shared-secret
HALO_TELEMETRY_ENDPOINT=
HALO_TELEMETRY_API_KEY=
